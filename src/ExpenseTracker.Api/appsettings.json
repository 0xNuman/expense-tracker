{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=expensetracker;Username=et;Password=et"
  },
  "Persistence": {
    "ApplyMigrationsOnStartup": true
  },
  "Auth": {
    "Jwt": {
      "Issuer": "expensetracker",
      "Audience": "expensetracker-client",
      "AccessTokenTtl": "00:15:00",
      "KeyId": "dev-1"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "FromAddress": "no-reply@expensetracker.local",
      "FromName": "Expense Tracker",
      "UseSsl": false,
      "SkipCertificateValidation": true
    }
  }
}
